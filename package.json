{
  "name": "dish",
  "main": "dist/index.js",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsx watch src/index.ts",
    "test": "tsc --noEmit",
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "start": "pnpm build && node .",
    "deploy": "pnpm build && node dist/deploy.js",
    "deployStart": "pnpm build && node dist/deploy.js && node ."
  },
  "packageManager": "pnpm@10.0.0",
  "dependencies": {
    "axios": "^1.7.2",
    "chalk": "4",
    "discord.js": "^14.21.0",
    "dotenv": "^16.4.5",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
